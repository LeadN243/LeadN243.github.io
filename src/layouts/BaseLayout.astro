---
const { title = "Your Name", description = "Academic portfolio", ogImage = "/og.png" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />

    <style>
      :root { color-scheme: light; }
      body { margin: 0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; line-height: 1.55; }
      a { text-decoration: none; }
      a:hover { text-decoration: underline; }
      .wrap { max-width: 980px; margin: 0 auto; padding: 24px; }
      nav { display: flex; gap: 14px; flex-wrap: wrap; padding: 10px 0 24px; }
      nav a { padding: 6px 10px; border-radius: 10px; }
      nav a:hover { background: rgba(0,0,0,0.06); text-decoration: none; }
      .hero { padding: 24px 0 12px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 14px; }
      .card { border: 1px solid rgba(0,0,0,0.12); border-radius: 16px; padding: 14px; }
      .tag { display: inline-block; font-size: 12px; padding: 4px 8px; border-radius: 999px; border: 1px solid rgba(0,0,0,0.15); margin-right: 6px; margin-top: 6px;}
      footer { padding: 32px 0 10px; font-size: 14px; opacity: 0.8; }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <nav>
        <a href="/">Home</a>
        <a href="/projects/">Projects</a>
        <a href="/research/">Research</a>
        <a href="/cv/">CV</a>
        <a href="/contact/">Contact</a>
      </nav>

      <main>
        <slot />
      </main>

      <footer>
        © {new Date().getFullYear()} Your Name · Built with Astro · Hosted on GitHub Pages
      </footer>
    </div>
  </body>
</html>