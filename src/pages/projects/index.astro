---
import BaseLayout from "../../layouts/BaseLayout.astro";
const projects = [
  {
    title: "Energy System Model — Portugal (PyPSA)",
    href: "/projects/pypsa-portugal/",
    tags: ["Python", "PyPSA", "Optimization"],
  },
  {
    title: "PV Tilt Optimization — Germany",
    href: "/projects/pv-tilt-germany/",
    tags: ["Python", "GIS", "Visualization"],
  },
  {
    title: "H2 Storage + NH3 Process Integration",
    href: "/projects/h2-nh3-integration/",
    tags: ["Aspen", "Thermodynamics", "Sensitivity"],
  },
];
---
<BaseLayout title="Projects — Your Name" description="Selected engineering and research projects.">
  <h1>Projects</h1>
  <p>Selected work with write-ups, results, and links to code/artifacts.</p>

  <div class="grid">
    {projects.map(p => (
      <article class="card">
        <h2 style="margin-top:0;"><a href={p.href}>{p.title}</a></h2>
        <div>
          {p.tags.map(t => <span class="tag">{t}</span>)}
        </div>
      </article>
    ))}
  </div>
</BaseLayout>